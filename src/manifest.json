{
  "name": "毛孩子健康本",
  "appid": "wxb2072e45bc057cc9",
  "description": "记录宠物健康点滴，关爱宠物每一天",
  "versionName": "1.0.0",
  "versionCode": "100",
  "transformPx": false,
  "app-plus": {
    "usingComponents": true,
    "nvueStyleCompiler": "uni-app",
    "compilerVersion": 3,
    "splashscreen": {
      "alwaysShowBeforeRender": true,
      "waiting": true,
      "autoclose": true,
      "delay": 0
    },
    "modules": {},
    "distribute": {
      "android": {
        "permissions": [
          "<uses-permission android:name=\"android.permission.CAMERA\"/>",
          "<uses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/>",
          "<uses-permission android:name=\"android.permission.WRITE_EXTERNAL_STORAGE\"/>"
        ]
      },
      "ios": {},
      "sdkConfigs": {}
    }
  },
  "quickapp": {},
  "mp-weixin": {
    "appid": "wxb2072e45bc057cc9",
    "cloud": true,
    "setting": {
      "urlCheck": false,
      "minified": true,
      "es6": true
    },
    "lazyCodeLoading": "requiredComponents",
    "usingComponents": true,
    "permission": {
      "scope.userLocation": {
        "desc": "用于自动定位您所在城市，展示同城红黑榜"
      }
    },
    "requiredPrivateInfos": ["getLocation"]
  },
  "uniStatistics": {
    "enable": false
  },
  "vueVersion": "3"
}
